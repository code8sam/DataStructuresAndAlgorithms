package com.codecean.easy;

public class SingleNumber {
	public static void main(String[]args) {
		
		int [] array = {4,1,2,1,2};
		
		for(int i=0;i<array.length;i++) {
			for (int j = 0; j < array.length; j++) {
				if(j!=-1 && j!=i && array[i]==array[j]) {
					continue;
				}else {
					System.out.println(array[i]);
				}
			}
		}
	}
}
